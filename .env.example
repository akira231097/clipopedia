# =============================================================================
# Clip'O'pedia — example environment configuration
# Copy to `.env` and fill in your own values. NEVER commit a real `.env`.
# Every value below is a placeholder; none of these are real credentials.
# =============================================================================

# ---- Runtime backend ---------------------------------------------------------
# "demo" wires deterministic, offline fakes (no network, no API keys needed).
# "live" wires the real OpenAI / Pinecone / Cohere / Gemini / AWS adapters.
CLIPOPEDIA_BACKEND=demo
CLIPOPEDIA_LOG_LEVEL=INFO

# ---- LLM / embedding providers ----------------------------------------------
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
COHERE_API_KEY=your-cohere-key

# ---- Vector store (Pinecone) ------------------------------------------------
PINECONE_API_KEY=your-pinecone-key
# One index with the `dotproduct` metric (holds both dense and sparse vectors).
PINECONE_INDEX=clip-hybrid
PINECONE_NAMESPACE=default

# Canonical entity catalog for fuzzy matching (guests / hosts / shows).
ENTITIES_PATH=data/entities.example.json

# ---- Metadata store (PostgreSQL) --------------------------------------------
# Standard libpq URL. Use your own host/credentials.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ---- Ingest queue (AWS SQS) -------------------------------------------------
AWS_REGION=us-east-1
# Format: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
MENTIONS_QUEUE_URL=https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>

# ---- Media storage (AWS S3) -------------------------------------------------
CLIP_BUCKET=your-clip-bucket-name

# ---- Social client (X / Twitter API) ----------------------------------------
TWITTER_CONSUMER_KEY=your-consumer-key
TWITTER_CONSUMER_SECRET=your-consumer-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
TWITTER_BEARER_TOKEN=your-bearer-token
BOT_HANDLE=@YourBotHandle

# ---- Tracing (optional) ------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=clipopedia
